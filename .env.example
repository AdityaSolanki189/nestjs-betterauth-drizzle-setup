# =============================================================================
# Application (NestJS)
# =============================================================================
# Port the Nest app listens on (see src/main.ts). Docker Compose maps this host:container.
APP_PORT=43127

# Conventional for production builds: NODE_ENV=production node dist/main
NODE_ENV=development

# Expose Swagger UI at /docs when NODE_ENV=production (default: disabled in production)
# SWAGGER_ENABLED=false

# =============================================================================
# Runtime database (postgres.js + Drizzle + Better Auth)
# =============================================================================
# Neon: use the connection string from the Neon dashboard (usually includes sslmode=require).
# Docker Compose (app container): host must be the service name, e.g. postgres — not localhost.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/core

# =============================================================================
# Drizzle Kit (migrations) + docker-compose Postgres service
# =============================================================================
# If POSTGRES_HOST=postgres, drizzle.config.ts maps it to localhost so migrations work from
# the host machine against the published port.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=core

# Set to true for TLS (e.g. Neon when using discrete host/user/password instead of URL in drizzle.config).
POSTGRES_SSL=false

# =============================================================================
# Better Auth (read from env when secret/baseURL are not set in code)
# =============================================================================
# Long random string. Alternate: AUTH_SECRET
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Full origin where this API is reachable (must match how clients call /api/auth).
BETTER_AUTH_URL=http://localhost:43127

# Optional: comma-separated origins for trusted origins / CORS-style allowlists when configured.
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:43127

# =============================================================================
# Stripe (@better-auth/stripe)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
